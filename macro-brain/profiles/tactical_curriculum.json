{
  "meta": {
    "name": "Tactical Decision-Making Curriculum",
    "version": "3.1.0",
    "description": "9-stage curriculum (0-8): 1v1 navigation → target selection → scouting → walls → pheromone → flanking → scout+retreat → combined → randomized. MultiDiscrete([8, 2500]) action space with CNN+MLP feature extractor."
  },
  "world": {
    "width": 1000.0,
    "height": 1000.0,
    "grid_width": 50,
    "grid_height": 50,
    "cell_size": 20.0
  },
  "factions": [
    {
      "id": 0,
      "name": "Brain",
      "role": "brain",
      "stats": { "hp": 100.0 },
      "default_count": 50
    },
    {
      "id": 1,
      "name": "EnemyA",
      "role": "bot",
      "stats": { "hp": 100.0 },
      "default_count": 50
    },
    {
      "id": 2,
      "name": "EnemyB",
      "role": "bot",
      "stats": { "hp": 100.0 },
      "default_count": 50
    }
  ],
  "combat": {
    "rules": [
      {
        "source_faction": 0, "target_faction": 1,
        "range": 25.0,
        "effects": [{ "stat_index": 0, "delta_per_second": -25.0 }]
      },
      {
        "source_faction": 1, "target_faction": 0,
        "range": 25.0,
        "effects": [{ "stat_index": 0, "delta_per_second": -25.0 }]
      },
      {
        "source_faction": 0, "target_faction": 2,
        "range": 25.0,
        "effects": [{ "stat_index": 0, "delta_per_second": -25.0 }]
      },
      {
        "source_faction": 2, "target_faction": 0,
        "range": 25.0,
        "effects": [{ "stat_index": 0, "delta_per_second": -25.0 }]
      }
    ]
  },
  "movement": {
    "max_speed": 60.0,
    "steering_factor": 5.0,
    "separation_radius": 6.0,
    "separation_weight": 1.5,
    "flow_weight": 1.0
  },
  "terrain_thresholds": {
    "impassable_threshold": 65535,
    "destructible_min": 60001
  },
  "removal_rules": [
    { "stat_index": 0, "threshold": 0.0, "condition": "LessOrEqual" }
  ],
  "abilities": {
    "buff_cooldown_ticks": 180,
    "movement_speed_stat": 1,
    "combat_damage_stat": 2,
    "zone_modifier_duration_ticks": 1500,
    "activate_buff": {
      "modifiers": [
        { "stat_index": 0, "modifier_type": "Multiplier", "value": 0.25 },
        { "stat_index": 2, "modifier_type": "Multiplier", "value": 0.25 }
      ],
      "duration_ticks": 9999
    }
  },
  "actions": [
    { "index": 0, "name": "Hold", "unlock_stage": 0 },
    { "index": 1, "name": "AttackCoord", "unlock_stage": 0 },
    { "index": 2, "name": "DropPheromone", "unlock_stage": 2 },
    { "index": 3, "name": "DropRepellent", "unlock_stage": 3 },
    { "index": 4, "name": "SplitToCoord", "unlock_stage": 5 },
    { "index": 5, "name": "MergeBack", "unlock_stage": 5 },
    { "index": 6, "name": "Retreat", "unlock_stage": 6 },
    { "index": 7, "name": "Scout", "unlock_stage": 4 }
  ],
  "training": {
    "max_density": 50.0,
    "max_steps": 1000,
    "ai_eval_interval_ticks": 30,
    "observation_channels": 9,
    "rewards": {
      "time_penalty_per_step": -0.01,
      "kill_reward": 0.05,
      "death_penalty": -0.03,
      "win_terminal": 10.0,
      "loss_terminal": -10.0,
      "survival_bonus_multiplier": 5.0,
      "approach_scale": 0.02,
      "exploration_reward": 0.005,
      "exploration_decay_threshold": 0.8,
      "threat_priority_bonus": 2.0,
      "flanking_bonus_scale": 0.1,
      "lure_success_bonus": 3.0,
      "debuff_bonus": 2.0
    },
    "curriculum": [
      {
        "stage": 0,
        "description": "1v1 Navigation: learn to aim AttackCoord at a single enemy group",
        "graduation": { "win_rate": 0.85, "min_episodes": 30 }
      },
      {
        "stage": 1,
        "description": "Target Selection: read density, pick correct target among distractors",
        "graduation": { "win_rate": 0.80, "min_episodes": 50 }
      },
      {
        "stage": 2,
        "description": "Pheromone Path: use DropPheromone to attract swarm through safe route, avoid trap on fast path",
        "graduation": { "win_rate": 0.80, "min_episodes": 50 }
      },
      {
        "stage": 3,
        "description": "Repellent Field: use DropRepellent to push swarm away from scattered trap groups",
        "graduation": { "win_rate": 0.80, "min_episodes": 50 }
      },
      {
        "stage": 4,
        "description": "Fog Scouting: use Scout to find hidden enemy in fog, navigate with LKP",
        "graduation": { "win_rate": 0.80, "min_episodes": 50 }
      },
      {
        "stage": 5,
        "description": "Flanking: split and pincer from two angles",
        "graduation": { "win_rate": 0.80, "min_episodes": 50, "avg_flanking_score_min": 0.3 }
      },
      {
        "stage": 6,
        "description": "Full Tactics: all 8 actions, combine primitives for complex maneuvers",
        "graduation": { "win_rate": 0.80, "min_episodes": 50 }
      },
      {
        "stage": 7,
        "description": "Protected Target: fog + scout + flank vs guarded HVT",
        "graduation": { "win_rate": 0.75, "min_episodes": 100 }
      },
      {
        "stage": 8,
        "description": "Full Tactical: random scenarios, any tactic",
        "graduation": { "win_rate": 0.80, "min_episodes": 500 }
      }
    ]
  },
  "bot_stage_behaviors": [
    { "stage": 0, "faction_id": 1, "strategy": { "type": "HoldPosition" }, "eval_interval_ticks": 60 },
    { "stage": 0, "faction_id": 2, "strategy": { "type": "HoldPosition" }, "eval_interval_ticks": 60 },
    { "stage": 1, "faction_id": 1, "strategy": { "type": "HoldPosition" }, "eval_interval_ticks": 60 },
    { "stage": 1, "faction_id": 2, "strategy": { "type": "HoldPosition" }, "eval_interval_ticks": 60 },
    { "stage": 2, "faction_id": 1, "strategy": { "type": "HoldPosition" }, "eval_interval_ticks": 60 },
    { "stage": 2, "faction_id": 2, "strategy": { "type": "HoldPosition" }, "eval_interval_ticks": 60 },
