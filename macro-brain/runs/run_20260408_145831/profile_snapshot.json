{
  "meta": {
    "name": "Swarm Combat 50v50",
    "version": "1.0.0",
    "description": "Symmetric swarm combat with abstract damage+speed buff and 5-stage curriculum"
  },

  "world": {
    "width": 1000.0,
    "height": 1000.0,
    "grid_width": 50,
    "grid_height": 50,
    "cell_size": 20.0
  },

  "factions": [
    {
      "id": 0,
      "name": "Swarm",
      "role": "brain",
      "stats": { "hp": 100.0 },
      "default_count": 50
    },
    {
      "id": 1,
      "name": "Defenders",
      "role": "bot",
      "stats": { "hp": 100.0 },
      "default_count": 50
    }
  ],

  "combat": {
    "rules": [
      {
        "source_faction": 0,
        "target_faction": 1,
        "range": 25.0,
        "effects": [{ "stat_index": 0, "delta_per_second": -25.0 }]
      },
      {
        "source_faction": 1,
        "target_faction": 0,
        "range": 25.0,
        "effects": [{ "stat_index": 0, "delta_per_second": -25.0 }]
      }
    ]
  },

  "movement": {
    "max_speed": 60.0,
    "steering_factor": 5.0,
    "separation_radius": 6.0,
    "separation_weight": 1.5,
    "flow_weight": 1.0
  },

  "terrain_thresholds": {
    "impassable_threshold": 65535,
    "destructible_min": 60001
  },

  "removal_rules": [
    { "stat_index": 0, "threshold": 0.0, "condition": "LessOrEqual" }
  ],

  "abilities": {
    "buff_cooldown_ticks": 180,
    "movement_speed_stat": 1,
    "combat_damage_stat": 2,
    "activate_buff": {
      "modifiers": [
        { "stat_index": 1, "modifier_type": "Multiplier", "value": 1.5 },
        { "stat_index": 2, "modifier_type": "Multiplier", "value": 1.5 }
      ],
      "duration_ticks": 60
    }
  },

  "actions": [
    { "index": 0, "name": "Hold",         "unlock_stage": 1 },
    { "index": 1, "name": "Navigate",     "unlock_stage": 1 },
    { "index": 2, "name": "ActivateBuff", "unlock_stage": 1 },
    { "index": 3, "name": "Retreat",       "unlock_stage": 2 },
    { "index": 4, "name": "ZoneModifier", "unlock_stage": 3 },
    { "index": 5, "name": "SplitFaction", "unlock_stage": 3 },
    { "index": 6, "name": "MergeFaction", "unlock_stage": 4 },
    { "index": 7, "name": "SetAggroMask", "unlock_stage": 4 }
  ],

  "training": {
    "max_density": 50.0,
    "max_steps": 500,
    "ai_eval_interval_ticks": 30,
    "observation_channels": 5,

    "rewards": {
      "time_penalty_per_step": -0.01,
      "kill_reward": 0.05,
      "death_penalty": -0.03,
      "win_terminal": 10.0,
      "loss_terminal": -10.0,
      "survival_bonus_multiplier": 5.0
    },

    "curriculum": [
      {
        "stage": 1,
        "description": "Learn to fight: 3 actions, symmetric 50v50, flat map",
        "graduation": {
          "win_rate": 0.80,
          "avg_survivors": 10.0,
          "min_episodes": 100
        },
        "demotion": null
      },
      {
        "stage": 2,
        "description": "Learn positioning: +Retreat, scattered defenders 2-3 groups",
        "graduation": {
          "win_rate": 0.85,
          "avg_survivors": 15.0,
          "min_episodes": 100,
          "action_usage": { "Retreat": 0.05 }
        },
        "demotion": { "win_rate_floor": 0.20, "window": 100 }
      },
      {
        "stage": 3,
        "description": "Learn army management: +SplitFaction +ZoneModifier, simple terrain",
        "graduation": {
          "win_rate": 0.75,
          "min_episodes": 150,
          "action_usage": { "SplitFaction": 0.05 },
          "avg_flanking_score_min": 0.0
        },
        "demotion": { "win_rate_floor": 0.20, "window": 100 }
      },
      {
        "stage": 4,
        "description": "Learn terrain tactics: full 8 actions, complex procedural terrain",
        "graduation": {
          "win_rate": 0.80,
          "min_episodes": 250,
          "timeout_rate_max": 0.05
        },
        "demotion": { "win_rate_floor": 0.20, "window": 100 }
      },
      {
        "stage": 5,
        "description": "Generalization: full 8 actions, mixed bot strategies, complex terrain",
        "graduation": {
          "win_rate": 0.85,
          "min_episodes": 300,
          "timeout_rate_max": 0.05
        },
        "demotion": { "win_rate_floor": 0.20, "window": 100 }
      }
    ]
  },

  "bot_stage_behaviors": [
    {
      "stage": 1,
      "faction_id": 1,
      "strategy": { "type": "Charge", "target_faction": 0 },
      "eval_interval_ticks": 60
    },
    {
      "stage": 2,
      "faction_id": 1,
      "strategy": { "type": "Charge", "target_faction": 0 },
      "eval_interval_ticks": 60
    },
    {
      "stage": 3,
      "faction_id": 1,
      "strategy": { "type": "HoldPosition", "x": 650.0, "y": 500.0 },
      "eval_interval_ticks": 60
    },
    {
      "stage": 4,
      "faction_id": 1,
      "strategy": {
        "type": "Adaptive",
        "target_faction": 0,
        "retreat_health_fraction": 0.3,
        "retreat_x": 900.0,
        "retreat_y": 500.0
      },
      "eval_interval_ticks": 60
    },
    {
      "stage": 5,
      "faction_id": 1,
      "strategy": {
        "type": "Mixed",
        "strategies": [
          { "type": "Charge", "target_faction": 0 },
          { "type": "HoldPosition", "x": 650.0, "y": 500.0 },
          {
            "type": "Adaptive",
            "target_faction": 0,
            "retreat_health_fraction": 0.3,
            "retreat_x": 900.0,
            "retreat_y": 500.0
          }
        ]
      },
      "eval_interval_ticks": 60
    }
  ]
}
