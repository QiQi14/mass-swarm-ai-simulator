# ============================================================
# Mass-Swarm AI Simulator — .gitignore
# ============================================================

# ── IDE / OS ─────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/
Thumbs.db
*.iml
*.log
*.swo
*.swp
*.tmp
*~

# ── Python / Macro-Brain ─────────────────────────────────────
__pycache__/
**/*.py[cod]
.pytest_cache/
.ruff_cache/
*.egg-info/
.venv/
venv/

# PyTorch / ONNX artifacts
macro-brain/**/*.onnx
macro-brain/**/*.pt
macro-brain/**/*.pth

# Training Outputs
macro-brain/checkpoints/
macro-brain/tb_logs/
macro-brain/runs/
episode_log.csv
train_log.txt

# ── Rust / Micro-Core ────────────────────────────────────────
micro-core/target/
**/*.rs.bk

# ── Debug Visualizer ─────────────────────────────────────────
debug-visualizer/node_modules/
debug-visualizer/dist/
node_modules/
verify_screenshot_*.png
test-console.js

# ── Agent Framework Runtime Artifacts ────────────────────────
# Python venvs for CLI tools
.venv_dispatch/
.venv_task_tool/

# Lock file (transient, per-machine)
.dev.pids
.task_state.lock
.task_state